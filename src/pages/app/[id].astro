---
/**
 * src/pages/app/[id].astro
 * App Detail Page — dynamic route
 * Contract: AppWow API Contract v1 — Section 3 (App Detail) + Section 4 (User State)
 * Data source: VTL Platform API via src/lib/api.ts ONLY
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAppDetail, getMe } from '../../lib/api';
import type { AppDetail, MeResponse } from '../../lib/api';

const { id } = Astro.params;

// ── DATA FETCH ──
let app: AppDetail | null = null;
let me: MeResponse = {
  authenticated: false,
  member: null,
  entitlements: {
    link3_stage1: false,
    link3_stage2: false,
    link3_stage3: false,
    linxmart_view: false,
    full_evosystem: false,
  },
  _phase: 1,
};

try {
  [app, me] = await Promise.all([
    getAppDetail(id!),
    getMe(),
  ]);
} catch (err: unknown) {
  // App not found or fetch failed — will render 404 state below
  const message = err instanceof Error ? err.message : String(err);
  if (!message.includes('not found')) {
    console.error('[AppWow] App detail fetch failed:', err);
  }
}

// 404 — redirect to homepage if app genuinely not found
if (!app) {
  throw new Response(null, { status: 404 });
}

// Parse screenshots if present
let screenshots: string[] = [];
if (app.screenshots_r2_keys) {
  try {
    screenshots = JSON.parse(app.screenshots_r2_keys);
  } catch {}
}

// Verification badge logic
const verificationLabel =
  app.verification_status === 'pass' ? 'Verified'  :
  app.verification_status === 'fail' ? 'Failed'    :
  'Pending scan';

const verificationColor =
  app.verification_status === 'pass' ? 'success' :
  app.verification_status === 'fail' ? 'danger'  :
  'neutral';
---

<BaseLayout
  title={`${app.app_name} — AppWow`}
  description={app.short_description ?? `Launch ${app.app_name} instantly on AppWow.`}
  me={me}
>

  <!-- ── BACK BAR ── -->
  <div class="back-bar">
    <a href="/" class="back-btn">← AppWow</a>
  </div>

  <!-- ── APP HEADER ── -->
  <section class="app-header">
    <div class="app-header-inner">

      <!-- Icon -->
      <div class="app-icon-wrap">
        {app.icon_r2_key
          ? <img
              src={`/media/${app.icon_r2_key}`}
              alt={`${app.app_name} icon`}
              width="96" height="96"
              class="app-icon-img"
            />
          : <div class="app-icon-placeholder">{app.app_name.charAt(0)}</div>
        }
        {app.is_evosystem === 1 && (
          <span class="badge-evosystem" title="VTL Evosystem app">✦</span>
        )}
      </div>

      <!-- Info -->
      <div class="app-header-info">
        <div class="app-header-meta">
          <span class="app-category">{app.category}</span>
          <span class={`app-verification app-verification--${verificationColor}`}>
            {verificationLabel}
            {app.verification_score !== null && (
              <span class="app-score">{app.verification_score}/100</span>
            )}
          </span>
        </div>
        <h1 class="app-title">{app.app_name}</h1>
        {app.short_description && (
          <p class="app-short-desc">{app.short_description}</p>
        )}
        <a
          href={app.app_url}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-launch"
          aria-label={`Launch ${app.app_name}`}
        >
          Launch App →
        </a>
      </div>

    </div>
  </section>

  <!-- ── SCREENSHOTS ── -->
  {screenshots.length > 0 && (
    <section class="screenshots-section" aria-label="Screenshots">
      <div class="screenshots-scroll">
        {screenshots.map((key, i) => (
          <img
            src={`/media/${key}`}
            alt={`${app!.app_name} screenshot ${i + 1}`}
            class="screenshot-img"
            loading="lazy"
          />
        ))}
      </div>
    </section>
  )}

  <!-- ── DESCRIPTION ── -->
  <section class="detail-section">
    <div class="detail-inner">
      <h2 class="detail-heading">About this app</h2>
      <p class="detail-body">{app.description}</p>
    </div>
  </section>

  <!-- ── DETAILS TABLE ── -->
  <section class="detail-section detail-section--grey">
    <div class="detail-inner">
      <h2 class="detail-heading">Details</h2>
      <dl class="detail-table">
        <div class="detail-row">
          <dt>Category</dt>
          <dd>{app.category}</dd>
        </div>
        <div class="detail-row">
          <dt>Type</dt>
          <dd>{app.is_evosystem === 1 ? 'VTL Evosystem' : 'Third Party'}</dd>
        </div>
        <div class="detail-row">
          <dt>Security scan</dt>
          <dd class={`detail-status detail-status--${verificationColor}`}>
            {verificationLabel}
            {app.verification_score !== null && ` — ${app.verification_score}/100`}
          </dd>
        </div>
        {app.last_verified_at && (
          <div class="detail-row">
            <dt>Last verified</dt>
            <dd>{new Date(app.last_verified_at).toLocaleDateString('en-GB', {
              day: 'numeric', month: 'long', year: 'numeric'
            })}</dd>
          </div>
        )}
        {app.manifest_url && (
          <div class="detail-row">
            <dt>Manifest</dt>
            <dd>
              <a href={app.manifest_url} target="_blank" rel="noopener noreferrer" class="detail-link">
                View manifest
              </a>
            </dd>
          </div>
        )}
      </dl>
    </div>
  </section>

  <!-- ── LAUNCH CTA ── -->
  <section class="launch-cta">
    <div class="launch-cta-inner">
      <p>Ready to use {app.app_name}?</p>
      <a
        href={app.app_url}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-launch btn-launch--large"
      >
        Launch {app.short_name ?? app.app_name} →
      </a>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── BACK BAR ── */
  .back-bar {
    background: var(--evo-dark);
    padding: .625rem 1.5rem;
    border-bottom: 1px solid rgba(255,255,255,.06);
  }
  .back-btn {
    color: rgba(255,255,255,.6);
    text-decoration: none;
    font-size: .85rem; font-weight: 600;
    transition: var(--transition);
  }
  .back-btn:hover { color: white; }

  /* ── APP HEADER ── */
  .app-header {
    background: linear-gradient(160deg, var(--evo-black) 0%, #0D1B2A 100%);
    padding: 2.5rem 1.5rem 3rem;
  }
  .app-header-inner {
    max-width: 860px; margin: 0 auto;
    display: flex; gap: 2rem; align-items: flex-start;
  }
  .app-icon-wrap { position: relative; flex-shrink: 0; }
  .app-icon-img {
    width: 96px; height: 96px;
    border-radius: 20px; object-fit: cover;
    box-shadow: 0 8px 24px rgba(0,0,0,.4);
  }
  .app-icon-placeholder {
    width: 96px; height: 96px;
    background: linear-gradient(135deg, var(--vtl-blue), var(--vtl-cyan));
    border-radius: 20px;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-display);
    font-size: 2.4rem; font-weight: 800; color: white;
    box-shadow: 0 8px 24px rgba(0,0,0,.3);
  }
  .badge-evosystem {
    position: absolute; bottom: -6px; right: -6px;
    width: 26px; height: 26px;
    background: linear-gradient(135deg, var(--vtl-blue), var(--vtl-cyan));
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: .7rem; color: white;
    border: 3px solid var(--evo-black);
  }

  .app-header-info { flex: 1; min-width: 0; }
  .app-header-meta {
    display: flex; gap: .75rem; align-items: center;
    flex-wrap: wrap; margin-bottom: .75rem;
  }
  .app-category {
    padding: .25rem .75rem;
    background: rgba(255,255,255,.08);
    border-radius: 99px;
    color: rgba(255,255,255,.65);
    font-size: .72rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: .06em;
  }
  .app-verification {
    display: inline-flex; align-items: center; gap: .4rem;
    padding: .25rem .75rem;
    border-radius: 99px;
    font-size: .72rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: .06em;
  }
  .app-verification--success { background: rgba(40,167,69,.15); color: #5cb85c; }
  .app-verification--danger  { background: rgba(220,53,69,.15);  color: #dc3545; }
  .app-verification--neutral { background: rgba(255,255,255,.08); color: rgba(255,255,255,.5); }
  .app-score { opacity: .75; font-size: .65rem; }

  .app-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 800; color: white;
    margin-bottom: .625rem; line-height: 1.1;
  }
  .app-short-desc {
    color: rgba(255,255,255,.6);
    font-size: .95rem; line-height: 1.6;
    margin-bottom: 1.5rem; max-width: 480px;
  }

  .btn-launch {
    display: inline-flex; align-items: center;
    padding: .8rem 1.75rem;
    background: var(--vtl-blue); color: white;
    text-decoration: none; border-radius: 12px;
    font-weight: 700; font-size: .9rem;
    transition: var(--transition);
    box-shadow: 0 4px 16px rgba(0,87,184,.4);
  }
  .btn-launch:hover { background: #0068d9; transform: translateY(-1px); }
  .btn-launch--large { padding: 1rem 2.25rem; font-size: 1rem; }

  /* ── SCREENSHOTS ── */
  .screenshots-section {
    padding: 1.5rem 1.5rem .5rem;
    background: #F9FAFB;
    border-bottom: 1px solid #E5E7EB;
  }
  .screenshots-scroll {
    display: flex; gap: 1rem;
    overflow-x: auto; padding-bottom: 1rem;
    scrollbar-width: none;
    max-width: 860px; margin: 0 auto;
  }
  .screenshots-scroll::-webkit-scrollbar { display: none; }
  .screenshot-img {
    height: 200px; width: auto;
    border-radius: 12px;
    border: 1px solid #E5E7EB;
    flex-shrink: 0;
    object-fit: cover;
  }

  /* ── DETAIL SECTIONS ── */
  .detail-section { padding: 2rem 1.5rem; }
  .detail-section--grey { background: #F9FAFB; }
  .detail-inner { max-width: 860px; margin: 0 auto; }
  .detail-heading {
    font-family: var(--font-display);
    font-size: 1.15rem; font-weight: 700;
    color: var(--evo-black); margin-bottom: 1rem;
  }
  .detail-body {
    color: var(--tech-grey);
    font-size: .95rem; line-height: 1.75;
    white-space: pre-wrap;
  }

  /* ── DETAILS TABLE ── */
  .detail-table { display: flex; flex-direction: column; gap: 0; }
  .detail-row {
    display: flex; justify-content: space-between; align-items: center;
    padding: .875rem 0;
    border-bottom: 1px solid #E5E7EB;
    gap: 1rem;
  }
  .detail-row:last-child { border-bottom: none; }
  .detail-row dt {
    font-size: .85rem; font-weight: 600;
    color: var(--tech-grey);
    flex-shrink: 0;
  }
  .detail-row dd {
    font-size: .85rem; color: var(--evo-black);
    font-weight: 500; text-align: right;
  }
  .detail-status { font-weight: 700; }
  .detail-status--success { color: #28a745; }
  .detail-status--danger  { color: #dc3545; }
  .detail-status--neutral { color: var(--mid-grey); }
  .detail-link {
    color: var(--vtl-blue); text-decoration: none; font-weight: 600;
  }
  .detail-link:hover { text-decoration: underline; }

  /* ── LAUNCH CTA ── */
  .launch-cta {
    background: var(--evo-dark);
    padding: 2.5rem 1.5rem;
    text-align: center;
  }
  .launch-cta-inner { max-width: 480px; margin: 0 auto; }
  .launch-cta p {
    color: rgba(255,255,255,.6);
    font-size: .95rem; margin-bottom: 1.25rem;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 540px) {
    .app-header-inner { flex-direction: column; gap: 1.25rem; }
    .app-icon-img, .app-icon-placeholder { width: 72px; height: 72px; }
  }
</style>